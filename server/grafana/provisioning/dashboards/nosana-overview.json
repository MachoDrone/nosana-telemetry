        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "id": 7,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Memory Usage %",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum by (host_name) (system_memory_usage_bytes{state=\"used\", host_name=~\"$host\"}) / sum by (host_name) (system_memory_usage_bytes{host_name=~\"$host\"})",
          "legendFormat": "{{host_name}}",
          "refId": "A"
        }
      ]
