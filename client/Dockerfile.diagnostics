FROM alpine:3.21
RUN apk add --no-cache bash bind-tools curl iputils coreutils yq docker-cli
COPY diagnostics.sh /usr/local/bin/diagnostics.sh
COPY playbooks.yaml /etc/diagnostics/playbooks.yaml
COPY VERSION /etc/diagnostics/VERSION
RUN chmod +x /usr/local/bin/diagnostics.sh
ENTRYPOINT ["/usr/local/bin/diagnostics.sh"]
